# Copy to .env and adjust for your machine. .env is gitignored.

# Absolute path to the Obsidian folder that holds your publishable articles.
# This is machine-specific (iCloud path differs per device) — never commit it.
# Example (macOS iCloud):
#   OBSIDIAN_OUTPUTS_DIR=/Users/you/Library/Mobile Documents/iCloud~md~obsidian/Documents/5. Outputs
OBSIDIAN_OUTPUTS_DIR=

# --- Optional: English-translation helper (scripts/translate.mjs) ---
# OpenAI-compatible endpoint used to draft English versions. Leave empty to skip.
TRANSLATE_BASE_URL=
TRANSLATE_API_KEY=
TRANSLATE_MODEL=gpt-5.5
